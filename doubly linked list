#include <stdio.h>
#define SIZE 100

int tree[SIZE];
int count = 0;

void insert(int value) {
    if (count == SIZE) {
        printf("Tree is full\n");
        return;
    }
    tree[count] = value;
    count++;
    printf("Inserted successfully\n");
}

void deleteValue(int value) {
    int i, index = -1;

    for (i = 0; i < count; i++) {
        if (tree[i] == value) {
            index = i;
            break;
        }
    }

    if (index == -1) {
        printf("Value not found\n");
        return;
    }

    tree[index] = tree[count - 1];
    count--;
    printf("Deleted successfully\n");
}

void display() {
    int i;
    if (count == 0) {
        printf("Tree is empty\n");
        return;
    }

    printf("Tree elements: ");
    for (i = 0; i < count; i++) {
        printf("%d ", tree[i]);
    }
    printf("\n");
}

int main() {
    int n, i, value, choice;

    printf("Enter number of elements to insert: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &value);
        insert(value);
    }

    while (1) {
        printf("\n1. Insert\n2. Delete\n3. Display\n4. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter value to insert: ");
                scanf("%d", &value);
                insert(value);
                break;

            case 2:
                printf("Enter value to delete: ");
                scanf("%d", &value);
                deleteValue(value);
                break;

            case 3:
                display();
                break;

            case 4:
                return 0;

            default:
                printf("Invalid choice\n");
        }
    }
}
